{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unichat",
  "version": "0.3.0",
  "identifier": "com.tcs.unichat",
  "build": {
    "beforeDevCommand": "bun run start",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist/unichat/browser"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "unichat",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; connect-src 'self' wss: https:; font-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["unichat"]
      }
    }
  }
}
